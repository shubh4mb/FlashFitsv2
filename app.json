{
  "expo": {
    "name": "FlashFits",
    "slug": "FlashFits",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.png",
    "scheme": "flashfits",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.flashfits.app",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/favicon.png",
        "backgroundImage": "./assets/images/favicon.png",
        "monochromeImage": "./assets/images/favicon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.flashfits.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow FlashFits to use your location for delivery services.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/favicon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "BACKEND_URL": "https://97a8-2405-201-f001-8ff-b00b-a574-926e-1561.ngrok-free.app",
      "router": {},
      "eas": {
        "projectId": "5ffa6730-d676-4b63-a03d-df1db41ca12b"
      }
    },
    "owner": "efron"
  }
}
